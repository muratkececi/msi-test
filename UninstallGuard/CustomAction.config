<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- DTF managed custom action'ın doğru .NET CLR ile yüklenmesini sağlar.
       Bu dosya olmadan modern makinelerde "SFXCA: Failed to get requested
       CLR info. Error code 0x80131700" hatası alınır ve CA 1603 ile çöker.
       useLegacyV2RuntimeActivationPolicy=true .NET 4.x için ZORUNLU. -->
  <startup useLegacyV2RuntimeActivationPolicy="true">
    <supportedRuntime version="v4.0.30319" />
  </startup>
</configuration>
