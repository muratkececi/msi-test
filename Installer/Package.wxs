<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="MyApp"
           Manufacturer="iCredible"
           Version="1.0.6"
           UpgradeCode="6E3B0C2A-9F1D-44A7-9C2E-7A1B2C3D4E5F"
           Codepage="65001"
           Scope="perMachine">

    <!-- Eski sürümleri otomatik kaldırma desteği -->
    <MajorUpgrade DowngradeErrorMessage="Daha yeni bir sürüm zaten kurulu." />

    <!-- Tek bir MSI dosyasında gömülü cab -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ============ DOSYALAR ============ -->
    <!-- Framework-dependent publish çıktısındaki tüm dosyalar:
         MyApp.exe + MyApp.dll + MyApp.runtimeconfig.json + MyApp.deps.json.
         $(var.PublishDir) Installer.wixproj içinde tanımlı. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="MyApp">
        <Component Id="MyAppExe" Guid="*">
          <File Id="MyAppExe"
                Source="$(var.PublishDir)MyApp.exe"
                KeyPath="yes" />
        </Component>
        <Component Id="MyAppDll" Guid="*">
          <File Source="$(var.PublishDir)MyApp.dll" KeyPath="yes" />
        </Component>
        <Component Id="MyAppRuntimeConfig" Guid="*">
          <File Source="$(var.PublishDir)MyApp.runtimeconfig.json" KeyPath="yes" />
        </Component>
        <Component Id="MyAppDepsJson" Guid="*">
          <File Source="$(var.PublishDir)MyApp.deps.json" KeyPath="yes" />
        </Component>

        <!-- ===== ARKA PLAN AJAN SERVICE'İ ===== -->
        <!-- Service exe + yan dosyaları, ServiceInstall + recovery ile. -->
        <Component Id="AgentServiceExe" Guid="*">
          <File Id="AgentServiceExe"
                Source="$(var.ServicePublishDir)MyApp.Service.exe"
                KeyPath="yes" />

          <!-- Service'i SYSTEM altında, otomatik başlatma ile kur. -->
          <ServiceInstall Id="AgentServiceInstall"
                          Name="MyAppAgent"
                          DisplayName="MyApp Agent"
                          Description="MyApp arka plan ajanı (korumalı)."
                          Type="ownProcess"
                          Start="auto"
                          ErrorControl="normal"
                          Account="LocalSystem"
                          Vital="no">
            <!-- Öldürülürse SCM yeniden başlatsın: ilk/ikinci/sonraki hatalarda
                 5 sn sonra restart; sayaç 1 günde sıfırlanır. -->
            <util:ServiceConfig FirstFailureActionType="restart"
                                SecondFailureActionType="restart"
                                ThirdFailureActionType="restart"
                                RestartServiceDelayInSeconds="5"
                                ResetPeriodInDays="1" />
          </ServiceInstall>

          <!-- Kaldırmada durdur ve sil. KURULUMDA BAŞLATMA YOK (Start yok):
               MSI'ın StartServices aksiyonu, service başlamazsa "Service failed
               to start ... Retry/Ignore" diyaloğunu HER ZAMAN gösterir ve bunu
               bastırmanın MSI/WiX yolu yoktur (Wait="no" bunu engellemez). Ayrıca
               "[1]" progress metni de buradan geliyordu. Bunun yerine service'i
               kurulum bittikten SONRA, sessiz bir custom action ile başlatıyoruz
               (StartAgentService) — başlamazsa kurulumu bozmaz. -->
          <ServiceControl Id="AgentServiceControl"
                          Name="MyAppAgent"
                          Stop="both"
                          Remove="uninstall"
                          Wait="no" />
        </Component>

        <Component Id="AgentServiceDll" Guid="*">
          <File Source="$(var.ServicePublishDir)MyApp.Service.dll" KeyPath="yes" />
        </Component>
        <Component Id="AgentServiceRuntimeConfig" Guid="*">
          <File Source="$(var.ServicePublishDir)MyApp.Service.runtimeconfig.json" KeyPath="yes" />
        </Component>
        <Component Id="AgentServiceDepsJson" Guid="*">
          <File Source="$(var.ServicePublishDir)MyApp.Service.deps.json" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Başlat menüsü kısayolu -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="MyApp">
        <Component Id="AppShortcut" Guid="*">
          <Shortcut Id="MyAppStartMenu"
                    Name="MyApp"
                    Target="[INSTALLFOLDER]MyApp.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\iCredible\MyApp"
                         Name="installed"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="MyApp" Level="1">
      <ComponentRef Id="MyAppExe" />
      <ComponentRef Id="MyAppDll" />
      <ComponentRef Id="MyAppRuntimeConfig" />
      <ComponentRef Id="MyAppDepsJson" />
      <ComponentRef Id="AgentServiceExe" />
      <ComponentRef Id="AgentServiceDll" />
      <ComponentRef Id="AgentServiceRuntimeConfig" />
      <ComponentRef Id="AgentServiceDepsJson" />
      <ComponentRef Id="AppShortcut" />
    </Feature>

    <!-- ============ .NET 9 DESKTOP RUNTIME KONTROLÜ ============ -->
    <!-- Framework-dependent olduğumuz için hedef makinede .NET 9 Desktop
         Runtime (WindowsDesktop.App) gerekli. Sürüm string'ine bağlı kalmamak
         ve registry bitness yönlendirme sorunlarından kaçınmak için, runtime'ın
         dosya sistemine bıraktığı klasörü arıyoruz:
         C:\Program Files\dotnet\shared\Microsoft.WindowsDesktop.App
         Klasör varsa bir Desktop runtime kurulu demektir. (WPF uygulaması
         Desktop runtime'a, service ise NETCore.App'e ihtiyaç duyar; Desktop
         runtime kurulumu NETCore.App'i de getirir, bu yüzden tek kontrol yeter.) -->
    <Property Id="NETDESKTOPRUNTIMEDIR">
      <DirectorySearch Id="DotnetRoot" Path="[ProgramFiles64Folder]dotnet\shared">
        <DirectorySearch Id="WindowsDesktopApp" Path="Microsoft.WindowsDesktop.App" />
      </DirectorySearch>
    </Property>

    <!-- Kurulu değilse anlamlı mesajla durdur. "Installed OR ..." sayesinde
         koşul yalnızca ilk kurulumda değerlendirilir; kaldırma/onarımda atlanır. -->
    <Launch Condition="Installed OR NETDESKTOPRUNTIMEDIR"
            Message="Bu uygulama .NET 9 (veya üzeri) Desktop Runtime gerektirir. Lütfen önce şu adresten kurun: https://dotnet.microsoft.com/download/dotnet/9.0/runtime (.NET Desktop Runtime x64)." />

    <!-- ============ UNINSTALL PAROLA KORUMASI ============ -->
    <!-- UninstallGuard.dll içindeki CheckUninstallPassword fonksiyonunu bağla -->
    <Binary Id="UninstallGuardBinary"
            SourceFile="$(var.UninstallGuard.TargetDir)UninstallGuard.CA.dll" />

    <CustomAction Id="CheckUninstallPassword"
                  BinaryRef="UninstallGuardBinary"
                  DllEntry="CheckUninstallPassword"
                  Execute="immediate"
                  Return="check" />

    <!-- ============ SERVICE'İ SESSİZ BAŞLATMA ============ -->
    <!-- Service kurulumda MSI tarafından BAŞLATILMAZ (Retry/Ignore diyaloğu ve
         "[1]" metnini önlemek için). Bunun yerine kurulum bittikten sonra burada
         sessizce başlatırız. Deferred + Impersonate="no" → SYSTEM altında çalışır
         (service'i başlatmaya yetki gerekir). Return="ignore" → service herhangi
         bir nedenle başlamazsa kurulum yine de BAŞARILI tamamlanır; service zaten
         Start="auto" olduğu için en geç bir sonraki açılışta çalışmaya başlar. -->
    <CustomAction Id="StartAgentService"
                  Directory="INSTALLFOLDER"
                  ExeCommand="[System64Folder]cmd.exe /c sc start MyAppAgent"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- Sadece KALDIRMA sırasında çalışsın (kurulum/onarım/upgrade değil).
           InstallValidate'ten önce, yani dosyalar silinmeden önce sorar.
           Parola yanlışsa Return="check" sayesinde tüm uninstall iptal olur. -->
      <Custom Action="CheckUninstallPassword"
              Before="InstallValidate"
              Condition="Installed AND (REMOVE=&quot;ALL&quot;) AND NOT UPGRADINGPRODUCTCODE AND NOT (WIX_UPGRADE_DETECTED)" />

      <!-- Service kayıt edildikten (InstallServices) sonra, kurulum bitmeden hemen
           önce sessizce başlat. Yalnızca kurma/onarım sırasında; kaldırmada değil. -->
      <Custom Action="StartAgentService"
              After="InstallServices"
              Condition="NOT REMOVE" />
    </InstallExecuteSequence>

    <!-- ============ KURULUM ARAYÜZÜ ============ -->
    <!-- InstallDirectory niteliği WIXUI_INSTALLDIR'i kendisi ayarlar;
         ayrıca elle Property tanımlamak çakışmaya yol açar. -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

  </Package>
</Wix>
