<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="MyApp"
           Manufacturer="iCredible"
           Version="1.0.9"
           UpgradeCode="6E3B0C2A-9F1D-44A7-9C2E-7A1B2C3D4E5F"
           Codepage="65001"
           Scope="perMachine">

    <!-- Automatic removal of older versions on upgrade -->
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <!-- Single MSI file with an embedded cab -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ============ FILES ============ -->
    <!-- Harvest the whole publish output instead of listing files one by one.
         A framework-dependent .NET 9 publish contains, besides
         exe/dll/runtimeconfig/deps, all the NuGet dependency DLLs (e.g.
         Microsoft.Extensions.Hosting.dll). Listing them by hand was error-prone:
         a single missing DLL crashed the service with
         "FileNotFoundException: Microsoft.Extensions.Hosting" so it never started.
         <Files> turns every file in the publish folder into a component
         automatically, so dependencies are always complete.
         $(var.PublishDir) / $(var.ServicePublishDir) are defined in Installer.wixproj. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="MyApp">

        <!-- The service lives in its own subfolder (Agent\) so the WPF and service
             publish outputs don't land in the same folder; this avoids collisions
             between identically-named DLLs from the two framework-dependent
             publishes (e.g. some Microsoft.*.dll). -->
        <Directory Id="AGENTFOLDER" Name="Agent">

          <!-- ===== BACKGROUND AGENT SERVICE ===== -->
          <!-- Service exe as a hand-authored component carrying ServiceInstall +
               recovery. Its dependency DLLs come from the <Files> group below. -->
          <Component Id="AgentServiceExe" Guid="*">
            <File Id="AgentServiceExe"
                  Source="$(var.ServicePublishDir)MyApp.Service.exe"
                  KeyPath="yes" />

          <!-- Install the service under SYSTEM with automatic start. -->
          <ServiceInstall Id="AgentServiceInstall"
                          Name="MyAppAgent"
                          DisplayName="MyApp Agent"
                          Description="MyApp background agent (protected)."
                          Type="ownProcess"
                          Start="auto"
                          ErrorControl="normal"
                          Account="LocalSystem"
                          Vital="no">
            <!-- If killed, let SCM restart it: on first/second/subsequent
                 failures restart after 5s; the counter resets after 1 day. -->
            <util:ServiceConfig FirstFailureActionType="restart"
                                SecondFailureActionType="restart"
                                ThirdFailureActionType="restart"
                                RestartServiceDelayInSeconds="5"
                                ResetPeriodInDays="1" />
          </ServiceInstall>

          <!-- Stop and remove on uninstall. NO START ON INSTALL (no Start attr):
               MSI's StartServices action ALWAYS shows the "Service failed to
               start ... Retry/Ignore" dialog when the service won't start, and
               there is no MSI/WiX way to suppress it (Wait="no" does not). The
               "[1]" progress text also came from here. Instead we start the
               service AFTER install via a silent custom action (StartAgentService)
               — if it fails to start, the install is not broken. -->
          <ServiceControl Id="AgentServiceControl"
                          Name="MyAppAgent"
                          Stop="both"
                          Remove="uninstall"
                          Wait="no" />
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- ComponentGroups that harvest the publish outputs in bulk.
         <Files> turns every file into a component automatically; we give the
         ComponentGroup an explicit Id so the Feature can reference it
         deterministically (a naked <Files>' auto-generated group Id is not
         predictable). WPF goes to the root folder (INSTALLFOLDER), the service
         to the Agent\ subfolder. -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <!-- The WPF app's full publish output (exe + all dependencies). -->
      <Files Include="$(var.PublishDir)**" />
    </ComponentGroup>

    <ComponentGroup Id="AgentFiles" Directory="AGENTFOLDER">
      <!-- The service's full publish output; only MyApp.Service.exe is excluded
           (we hand-authored it above with ServiceInstall, otherwise the same file
           would be defined twice). All other DLLs come from here. -->
      <Files Include="$(var.ServicePublishDir)**">
        <Exclude Files="$(var.ServicePublishDir)MyApp.Service.exe" />
      </Files>
    </ComponentGroup>

    <!-- Start menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="MyApp">
        <Component Id="AppShortcut" Guid="*">
          <Shortcut Id="MyAppStartMenu"
                    Name="MyApp"
                    Target="[INSTALLFOLDER]MyApp.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\iCredible\MyApp"
                         Name="installed"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="MyApp" Level="1">
      <!-- All WPF app files (INSTALLFOLDER) -->
      <ComponentGroupRef Id="AppFiles" />
      <!-- Service dependency DLLs (Agent\) -->
      <ComponentGroupRef Id="AgentFiles" />
      <!-- Hand-authored service exe component carrying ServiceInstall -->
      <ComponentRef Id="AgentServiceExe" />
      <ComponentRef Id="AppShortcut" />
    </Feature>

    <!-- ============ .NET 9 DESKTOP RUNTIME CHECK ============ -->
    <!-- Being framework-dependent, the target machine needs the .NET 9 Desktop
         Runtime (WindowsDesktop.App). To avoid depending on a version string and
         to sidestep registry bitness-redirection issues, we look for the folder
         the runtime drops on disk:
         C:\Program Files\dotnet\shared\Microsoft.WindowsDesktop.App
         If the folder exists, a Desktop runtime is installed. (The WPF app needs
         the Desktop runtime, the service needs NETCore.App; installing the
         Desktop runtime also brings NETCore.App, so one check is enough.) -->
    <Property Id="NETDESKTOPRUNTIMEDIR">
      <DirectorySearch Id="DotnetRoot" Path="[ProgramFiles64Folder]dotnet\shared">
        <DirectorySearch Id="WindowsDesktopApp" Path="Microsoft.WindowsDesktop.App" />
      </DirectorySearch>
    </Property>

    <!-- If not installed, stop with a meaningful message. Thanks to "Installed OR
         ...", the condition is only evaluated on first install; it is skipped on
         uninstall/repair. -->
    <Launch Condition="Installed OR NETDESKTOPRUNTIMEDIR"
            Message="This application requires the .NET 9 (or later) Desktop Runtime. Please install it first from: https://dotnet.microsoft.com/download/dotnet/9.0/runtime (.NET Desktop Runtime x64)." />

    <!-- ============ UNINSTALL PAROLA KORUMASI ============ -->
    <!-- Bind the CheckUninstallPassword function from UninstallGuard.dll -->
    <Binary Id="UninstallGuardBinary"
            SourceFile="$(var.UninstallGuard.TargetDir)UninstallGuard.CA.dll" />

    <CustomAction Id="CheckUninstallPassword"
                  BinaryRef="UninstallGuardBinary"
                  DllEntry="CheckUninstallPassword"
                  Execute="immediate"
                  Return="check" />

    <!-- ============ START THE SERVICE SILENTLY ============ -->
    <!-- The service is NOT started by MSI during install (to avoid the
         Retry/Ignore dialog and the "[1]" text). Instead we start it silently
         here after install completes. Deferred + Impersonate="no" runs it as
         SYSTEM (starting a service requires privilege). Return="ignore" means
         if the service fails to start for any reason the install still SUCCEEDS;
         since Start="auto", it will run by the next boot at the latest. -->
    <!-- TEMP DEBUG: the trailing `ping ... -n 3` adds a ~2s delay so the progress
         text stays on screen long enough to read while we verify the [1] [2] fix.
         REMOVE this delay (revert ExeCommand to just `sc start MyAppAgent`) once
         confirmed. -->
    <CustomAction Id="StartAgentService"
                  Directory="INSTALLFOLDER"
                  ExeCommand="[System64Folder]cmd.exe /c sc start MyAppAgent &amp; ping 127.0.0.1 -n 3 &gt; nul"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ============ REMOVE SERVICE-STOP PROTECTION ON UNINSTALL ============ -->
    <!-- At runtime the service adds a deny ACE for SERVICE_STOP (Interactive) to
         its own security descriptor, so services.msc / `sc stop` are blocked.
         During uninstall that ACE would also block MSI's StopServices. Run the
         service exe in unprotect mode (which only strips the ACE and exits)
         BEFORE StopServices, as SYSTEM, so the service can then be stopped and
         removed. Return="ignore" so uninstall never fails because of this. -->
    <CustomAction Id="UnprotectAgentService"
                  Directory="AGENTFOLDER"
                  ExeCommand="&quot;[AGENTFOLDER]MyApp.Service.exe&quot; --unprotect"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- TEMP DEBUG: a do-nothing 2s delay scheduled right AFTER InstallServices so
         the InstallServices / service-config progress text stays readable while we
         verify the [1] [2] fix. REMOVE this action and its sequencing afterwards. -->
    <CustomAction Id="DebugPauseAfterInstallServices"
                  Directory="INSTALLFOLDER"
                  ExeCommand="[System64Folder]cmd.exe /c ping 127.0.0.1 -n 3 &gt; nul"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- TEMP DEBUG: see CustomAction above. Runs only on install/repair. -->
      <Custom Action="DebugPauseAfterInstallServices"
              After="InstallServices"
              Condition="NOT REMOVE" />

      <!-- Run only during UNINSTALL (not install/repair/upgrade). Before
           InstallValidate, i.e. it prompts before any files are removed. On a
           wrong password, Return="check" cancels the entire uninstall. -->
      <Custom Action="CheckUninstallPassword"
              Before="InstallValidate"
              Condition="Installed AND (REMOVE=&quot;ALL&quot;) AND NOT UPGRADINGPRODUCTCODE AND NOT (WIX_UPGRADE_DETECTED)" />

      <!-- After the service is registered (InstallServices), start it silently
           just before install finishes. Install/repair only, not uninstall. -->
      <Custom Action="StartAgentService"
              After="InstallServices"
              Condition="NOT REMOVE" />

      <!-- On uninstall, strip the SERVICE_STOP deny ACE before MSI tries to stop
           the service (StopServices), so the stop/remove can proceed. Runs only
           when the service is actually being removed. -->
      <Custom Action="UnprotectAgentService"
              Before="StopServices"
              Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    <!-- ============ INSTALL UI ============ -->
    <!-- The InstallDirectory attribute sets WIXUI_INSTALLDIR itself;
         defining the Property manually as well would cause a conflict. -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Give every action that runs during install/uninstall an explicit
         ActionText row with a token-free message. Inspecting the built MSI showed
         the leaking "[1] [2]" did NOT come from InstallServices (we already
         overrode it) but from actions that had NO ActionText row of their own:
         our deferred custom actions (StartAgentService, UnprotectAgentService)
         and the WixUtil service-config custom action. When an action has no
         ActionText row, Windows Installer shows a built-in default template that
         can contain [1]/[2]. Adding a clean row for each kills it.
         Message = the line shown above the progress bar (Description column),
         Template = the detail line (Template column); both kept token-free. -->
    <UI>
      <ProgressText Action="InstallServices" Message="Background service" Template="Configuring the background service" />
      <ProgressText Action="StartServices"   Message="Background service" Template="Starting the background service" />
      <ProgressText Action="StopServices"    Message="Background service" Template="Stopping the background service" />
      <ProgressText Action="DeleteServices"  Message="Background service" Template="Removing the background service" />

      <!-- Our own custom actions. -->
      <ProgressText Action="StartAgentService"     Message="Starting background service" Template="Starting background service" />
      <ProgressText Action="UnprotectAgentService" Message="Preparing background service for removal" Template="Preparing background service for removal" />
      <ProgressText Action="CheckUninstallPassword" Message="Verifying uninstall password" Template="Verifying uninstall password" />
      <!-- TEMP DEBUG action: give it a clean row too so IT doesn't show [1] [2]. -->
      <ProgressText Action="DebugPauseAfterInstallServices" Message="Configuring background service" Template="Configuring background service" />

      <!-- WixUtil's service-config custom actions (recovery settings). Their
           default progress template is the most likely source of the raw
           "[1] [2]" because they run right after InstallServices and ship no
           ActionText row. The X64 suffix matches the InstallerPlatform=x64 build. -->
      <ProgressText Action="Wix4SchedServiceConfig_X64" Message="Configuring service recovery" Template="Configuring service recovery" />
      <ProgressText Action="Wix4ExecServiceConfig_X64"  Message="Configuring service recovery" Template="Configuring service recovery" />
    </UI>

  </Package>
</Wix>
